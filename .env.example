# =============================================================================
# Environment Variables — Portfolio Website
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# =============================================================================

# --- AI Chatbot (OpenAI) ---
CHATBOT_API_KEY=sk-your-openai-api-key-here

# --- Contact Form (Resend) ---
RESEND_API_KEY=re_your-resend-api-key-here

# --- AWS (for CDK deployment) ---
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-central-1

# --- Analytics (Plausible — optional) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=reebal-sami.com

# --- Site URL (set after domain purchase) ---
NEXT_PUBLIC_SITE_URL=https://reebal-sami.com
